generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum SubscriptionType {
  FREE
  PAID
}

enum OTPType {
  RESET
  LOGIN
  VERIFY
}

enum OAuthType {
  GOOGLE
  GITHUB
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum DeviceType {
  MOBILE
  DESKTOP
  TABLET
}

enum OSType {
  ANDROID
  IOS
  WINDOWS
  MACOS
  LINUX
}

enum BrowserType {
  CHROME
  FIREFOX
  SAFARI
  EDGE
}

model User {
  id        String      @id @default(uuid())
  email     String   @unique
  passwordHashed  String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      Role      @default(USER)
  isVerified Boolean  @default(false)
  links     Link[]
  otps      OTP[]
  oAuthAccounts OAuthAccount[]
  refreshTokens RefreshToken[]
  subscriptions Subscription?
}

model OAuthAccount {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete:Cascade )
  type      OAuthType
  providerId String
  createdAt DateTime @default(now())

  @@index([userId])
  @@unique([providerId, type])
}

model RefreshToken {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete:Cascade )
  tokenHashed     String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

model Subscription {
  id        String      @id @default(uuid())
  userId    String      @unique
  user      User        @relation(fields: [userId], references: [id], onDelete:Cascade )
  type      SubscriptionType
  status    SubscriptionStatus
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model OTP {
  id        String      @id @default(uuid())
  email     String
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete:Cascade )
  type      OTPType
  code      String
  isVerified  Boolean @default(false)
  attempts  Int     @default(0)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([email, type, isVerified])
  @@index([expiresAt])
}

model Link {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete:Cascade )
  slug      String      @unique
  title     String
  isPasswordProtected Boolean @default(false)
  passwordHashed  String?
  totalClicks Int @default(0)
  tags      String[]
  color     String?
  isActive   Boolean @default(true)
  isDeleted  Boolean @default(false)
  destinationUrl       String @db.Text
  createdAt DateTime @default(now())
  expiresAt DateTime?
  updatedAt DateTime @updatedAt
  clicks    LinkClick[]

  @@index([userId])
}

model LinkClick {
  id        String      @id @default(uuid())
  linkId    String
  link      Link        @relation(fields: [linkId], references: [id], onDelete:Cascade )
  clickedAt DateTime @default(now())
  device    DeviceType
  browser   BrowserType
  os        OSType
  ipHashed  String
  country   String
  refer     String?
  utm_source String?
  utm_campaign String?
  utm_medium String?
  utm_term String?
  utm_content String?

  @@index([linkId])
  @@index([os])
  @@index([country])
  @@index([utm_source])
}


